# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=

# LLM provider used by KG construction and online planning
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_MAX_TOKEN=1500
LLM_REQUEST_TIMEOUT=500
LLM_MAX_RETRIES=3

# Feature/vector services
FEATURE_URI=http://127.0.0.1:8001
FEATURE_MODEL=resnet50
FEATURE_DEVICE=cpu
OMNI_URI=http://127.0.0.1:8000
PINECONE_API_KEY=
PINECONE_INDEX=

# Online inference defaults
EAM_APP_NAME=
EAM_START_PAGE_ID=
EAM_PLAN_LOG_DIR=artifacts/plans
